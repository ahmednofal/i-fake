# ─────────────────────────────────────────────
#  i-fake configuration — copy to .env and fill
# ─────────────────────────────────────────────

# ── AI Provider ───────────────────────────────
# Which provider to use: gemini | openai | anthropic | local
IFAKE_AI_PROVIDER=gemini

# Google Gemini — FREE tier, best free option
# Get key at: https://aistudio.google.com/app/apikey
IFAKE_GEMINI_API_KEY=AIzaSyAdpGXdx2zgNymUhtyexiW40QU6wu7PZek
IFAKE_GEMINI_MODEL=gemini-2.5-flash

# OpenAI
IFAKE_OPENAI_API_KEY=sk-...
IFAKE_OPENAI_MODEL=gpt-4o

# Anthropic
IFAKE_ANTHROPIC_API_KEY=sk-ant-...
IFAKE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local (Ollama / llama.cpp / LM Studio — OpenAI-compatible)
IFAKE_LOCAL_MODEL_URL=http://localhost:11434/v1
IFAKE_LOCAL_MODEL_NAME=llama3

# ── Browser ───────────────────────────────────
IFAKE_HEADLESS=true
IFAKE_BROWSER_TYPE=chromium    # chromium | firefox | webkit
# IFAKE_PROXY_URL=http://user:pass@host:port
IFAKE_SLOW_MO_MS=0

# ── Personas ──────────────────────────────────
IFAKE_MAX_ACTIVE_PERSONAS=5
IFAKE_PERSONA_ROTATION_DAYS=7

# ── Scheduling ────────────────────────────────
IFAKE_SESSIONS_PER_DAY=3
IFAKE_MIN_SESSION_GAP_MINUTES=60

# ── Misc ──────────────────────────────────────
IFAKE_LOG_LEVEL=INFO
